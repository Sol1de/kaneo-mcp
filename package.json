{
  "name": "kaneo-mcp",
  "version": "1.0.0",
  "description": "MCP server for Kaneo — self-hosted Kanban project management",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "kaneo-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx --env-file=.env src/server.ts",
    "build:bundle": "esbuild dist/server.js --bundle --platform=node --target=node22 --format=cjs --outfile=build/kaneo-mcp.cjs --external:bufferutil --external:utf-8-validate",
    "build:binary": "./scripts/build-binary.sh"
  },
  "keywords": [
    "mcp",
    "kaneo",
    "kanban",
    "project-management"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/node": "^2.0.0-alpha.2",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "hono": "^4.12.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
