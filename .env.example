KANEO_URL=https://your-kaneo-instance.com
KANEO_WORKSPACE_ID=your-workspace-id
MCP_PORT=3000

# OAuth (optional — set ZITADEL_ISSUER to enable)
# ZITADEL_ISSUER=https://auth.example.com
# ZITADEL_AUDIENCE=your-zitadel-client-id
# MCP_SERVER_ORIGIN=https://mcp.example.com:3000
# KANEO_DEFAULT_API_KEY=kaneo_live_fallback_key
# KANEO_USER_TOKEN_MAP={"user@example.com":"kaneo_live_abc","other@example.com":"kaneo_live_xyz"}
